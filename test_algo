//@version=5
strategy("TFG ALGO v4", overlay=true,
     margin_long=100,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100,
     pyramiding=0, calc_on_every_tick=false,
     slippage=2, commission_type=strategy.commission.percent, commission_value=0.1,
     process_orders_on_close=false, max_bars_back=500)

// ============================================================
//  SPOT SCALP — LONG ONLY — NON-REPAINTING
//  Optimised for 3m BTC/ETH/BNB spot on Binance
// ============================================================

// ===========================
//  1. INPUTS
// ===========================

riskPct       = input.float(1.5,  "Risk % Per Trade",        minval=0.1,  maxval=5.0,  step=0.1,  group="Risk Management")
slPct         = input.float(0.3,  "Stop Loss %",             minval=0.05, maxval=1.0,  step=0.05, group="Risk Management")
tp1Pct        = input.float(0.4,  "TP1 %",                   minval=0.1,  maxval=2.0,  step=0.05, group="Risk Management")
tp2Pct        = input.float(0.7,  "TP2 %",                   minval=0.1,  maxval=3.0,  step=0.1,  group="Risk Management")
tp1ClosePct   = input.int(50,     "TP1 Close % of Position", minval=10,   maxval=90,              group="Risk Management")
useTrail      = input.bool(true,  "Enable Trailing Stop",                                          group="Risk Management")
trailPct      = input.float(0.35, "Trail Activation %",      minval=0.05, maxval=2.0,  step=0.05, group="Risk Management")
trailOffset   = input.float(0.18, "Trail Offset %",          minval=0.05, maxval=1.0,  step=0.05, group="Risk Management")

emaFastLen    = input.int(9,   "Fast EMA",                   minval=2,  group="Moving Averages")
emaSlowLen    = input.int(21,  "Slow EMA",                   minval=5,  group="Moving Averages")
emaTrendLen   = input.int(50,  "Trend EMA",                  minval=10, group="Moving Averages")
emaSlopeLen   = input.int(5,   "EMA Slope Lookback (bars)",  minval=2,  maxval=20, group="Moving Averages")

rsiLen        = input.int(7,  "RSI Length",                  minval=2, group="RSI")
rsiOB         = input.int(75, "RSI Overbought",                        group="RSI")
rsiOS         = input.int(30, "RSI Oversold",                          group="RSI")
rsiDivLookback= input.int(5,  "RSI Divergence Lookback",     minval=3, maxval=20, group="RSI")

macdFast      = input.int(8,  "MACD Fast",   group="MACD")
macdSlow      = input.int(21, "MACD Slow",   group="MACD")
macdSig       = input.int(5,  "MACD Signal", group="MACD")

volLen        = input.int(14,    "Volume SMA Length",        group="Volume")
volMult       = input.float(1.3, "Volume Spike Multiplier",  step=0.1, group="Volume")

useVWAP       = input.bool(true, "Use VWAP Bias Filter", group="VWAP")

useSR          = input.bool(true,  "Use S/R Levels",                    group="S/R Levels")
srLookback     = input.int(20,    "S/R Lookback Bars",      minval=5,  maxval=100, group="S/R Levels")
srProximity    = input.float(0.15, "Support Proximity %",   minval=0.05, maxval=0.5, step=0.05, group="S/R Levels")
resistProxPct  = input.float(0.2,  "Resistance Block %",    minval=0.05, maxval=1.0, step=0.05, group="S/R Levels")

adxLen        = input.int(10, "ADX Length",  minval=5, group="ADX")
adxMin        = input.int(15, "ADX Minimum",           group="ADX")

useHTF        = input.bool(true,  "Use HTF Trend Filter",   group="HTF")
htfTF         = input.timeframe("15", "Higher Timeframe",   group="HTF")

useSess       = input.bool(false, "Enable Session Filter",               group="Session")
sessStart     = input.int(8,  "Session Start Hour", minval=0, maxval=23, group="Session")
sessEnd       = input.int(20, "Session End Hour",   minval=0, maxval=23, group="Session")

minBuyScore       = input.int(6,  "Min Score (out of 10)",              minval=3, maxval=10, group="Filters")
entryCooldownBars = input.int(3,  "Entry Cooldown (bars)",              minval=1,            group="Filters")
exitCooldownBars  = input.int(1,  "Exit Cooldown (bars)",               minval=0,            group="Filters")
consLossMax       = input.int(2,  "Max Consecutive Losses before pause",minval=1, maxval=5,  group="Filters")
consLossCooldown  = input.int(10, "Consecutive Loss Cooldown (bars)",   minval=3, maxval=50, group="Filters")
dedupBars         = input.int(5,  "Signal Dedup Window (bars)",         minval=2, maxval=20, group="Filters")
atrMoveMult       = input.float(0.4, "Min Candle Range (× ATR)",        minval=0.1, maxval=2.0, step=0.1, group="Filters")

showLines     = input.bool(true, "Show TP/SL Lines Per Trade", group="Visuals")
lineWidth     = input.int(1,     "TP/SL Line Width", minval=1, maxval=3, group="Visuals")

// ===========================
//  2. INDICATORS
// ===========================

emaFast  = ta.ema(close, emaFastLen)
emaSlow  = ta.ema(close, emaSlowLen)
emaTrend = ta.ema(close, emaTrendLen)
vwapVal  = ta.vwap(hlc3)
rsi      = ta.rsi(close, rsiLen)
atr      = ta.atr(14)

[macdLine, signalLine, macdHist] = ta.macd(close, macdFast, macdSlow, macdSig)
[diPlus, diMinus, adx]           = ta.dmi(adxLen, adxLen)

volAvg   = ta.sma(volume[1], volLen)
volSpike = volume > volAvg * volMult

candleBody  = math.abs(close - open)
candleRange = high - low
bodyRatio   = candleRange > 0 ? candleBody / candleRange : 0
upperWick   = high - math.max(close, open)
lowerWick   = math.min(close, open) - low

// ===========================
//  2a. S/R LEVELS
// ===========================

pivotLow  = ta.pivotlow(low, 5, 5)
pivotHigh = ta.pivothigh(high, 5, 5)

var float supportLevel    = na
var float resistanceLevel = na
var int   supportSetBar   = 0
var int   resistanceSetBar= 0

if not na(pivotLow)
    supportLevel  := pivotLow
    supportSetBar := bar_index
if not na(pivotHigh)
    resistanceLevel   := pivotHigh
    resistanceSetBar  := bar_index

srMaxAge = srLookback * 3
if bar_index - supportSetBar > srMaxAge
    supportLevel := na
if bar_index - resistanceSetBar > srMaxAge
    resistanceLevel := na

nearSupport    = useSR and not na(supportLevel)    ? (close - supportLevel)    / close * 100 < srProximity   and close > supportLevel    : false
nearResistance = useSR and not na(resistanceLevel) and close < resistanceLevel ? (resistanceLevel - close) / close * 100 < resistProxPct : false

// ===========================
//  2b. CANDLE PATTERNS
// ===========================

bullEngulf  = close > open and close[1] < open[1] and close > open[1] and open < close[1] and bodyRatio > 0.5
bullPinBar  = lowerWick > candleBody * 2 and upperWick < candleBody and close > open and bodyRatio > 0.2 and close > open[1] * 0.995
strongBull  = close > open and bodyRatio > 0.6 and upperWick < candleBody * 0.3
bullPattern = bullEngulf or bullPinBar or strongBull
bullCandle  = close > open and bodyRatio > 0.35

// ===========================
//  2c. HTF — NON-REPAINTING
// ===========================

htfEmaFast = request.security(syminfo.tickerid, htfTF, ta.ema(close, emaFastLen)[1], lookahead=barmerge.lookahead_off)
htfEmaSlow = request.security(syminfo.tickerid, htfTF, ta.ema(close, emaSlowLen)[1], lookahead=barmerge.lookahead_off)
htfBull    = useHTF ? htfEmaFast > htfEmaSlow : true

// ===========================
//  2d. SESSION
// ===========================

inSession = useSess ? (hour(time, syminfo.timezone) >= sessStart and hour(time, syminfo.timezone) < sessEnd) : true

// ===========================
//  2e. RSI BEARISH DIVERGENCE
// ===========================

priceHH    = high > ta.highest(high[1], rsiDivLookback)
rsiHH      = rsi  > ta.highest(rsi[1],  rsiDivLookback)
rsiBearDiv = priceHH and not rsiHH and rsi < rsiOB - 5

// ===========================
//  2f. TREND EMA SLOPE FILTER
// ===========================

emaTrendSlope = emaTrend > emaTrend[emaSlopeLen]

// ===========================
//  2g. ATR MOVE FILTER
// ===========================

atrMoveOK = candleRange >= atr * atrMoveMult

// ===========================
//  3. CONFLUENCE SCORE
// ===========================

emaCross = ta.crossover(emaFast, emaSlow)

c_trend    = close > emaTrend ? 1 : 0
c_vwap     = (useVWAP ? close > vwapVal : true) ? 1 : 0
c_volume   = volSpike ? 1 : 0
c_rsi      = (rsi > rsiOS and rsi < rsiOB) ? 1 : 0
c_macd     = (macdLine > signalLine and macdHist > macdHist[1]) ? 1 : 0
c_candle   = bullCandle ? 1 : 0
c_support  = nearSupport ? 1 : 0
c_di       = (diPlus > diMinus) ? 1 : 0
c_adx      = (adx > adxMin) ? 1 : 0
c_breakout = (close > ta.highest(high[1], 3)) ? 1 : 0

totalScore = c_trend + c_vwap + c_volume + c_rsi + c_macd + c_candle + c_support + c_di + c_adx + c_breakout

// ===========================
//  4. COOLDOWN & LOSS TRACKING
// ===========================

var int lastEntryBar      = 0
var int lastExitBar       = -100
var int lastSignalBar     = -100
var int consLosses        = 0
var int consLossPauseBar  = 0
var int prevClosedTrades  = 0

consLossBlocked = consLosses >= consLossMax and (bar_index - consLossPauseBar) < consLossCooldown

entryCooldownOK = bar_index - lastEntryBar  >= entryCooldownBars
exitCooldownOK  = bar_index - lastExitBar   >= exitCooldownBars
dedupOK         = bar_index - lastSignalBar >= dedupBars
cooldownOK      = entryCooldownOK and exitCooldownOK and dedupOK and not consLossBlocked

// ===========================
//  5. ENTRY SIGNALS
// ===========================

coreGuards = htfBull and cooldownOK and inSession and strategy.position_size == 0
             and emaTrendSlope
             and not nearResistance
             and not rsiBearDiv
             and atrMoveOK

buySignal  = emaCross    and totalScore >= minBuyScore and coreGuards
patternBuy = bullPattern and not emaCross and totalScore >= 8 and coreGuards
finalBuy   = buySignal or patternBuy

// ===========================
//  6. VAR STATE — LEVELS & LINES
// ===========================

var float longSL            = na
var float longTP1           = na
var float longTP2           = na
var float trailTicksLocked  = na
var float trailOffsetLocked = na
var bool  tp1Hit            = false

// Per-trade line objects — deleted and redrawn on each new entry
var line  slLine  = na
var line  tp1Line = na
var line  tp2Line = na
var line  entLine = na

// ===========================
//  7. EXIT CONDITIONS
// ===========================

emaSellCross  = ta.crossunder(emaFast, emaSlow)
trendBreak    = close < emaTrend and close[1] >= emaTrend
rsiExhaust    = rsi[1] >= rsiOB and rsi < rsiOB
macdBearCross = ta.crossunder(macdLine, signalLine)
diFlip        = diMinus > diPlus and diPlus[1] >= diMinus[1]
belowVWAP     = useVWAP and close < vwapVal and close[1] >= vwapVal

exitCount  = (emaSellCross ? 1 : 0) + (trendBreak ? 1 : 0) + (rsiExhaust ? 1 : 0) + (macdBearCross ? 1 : 0) + (diFlip ? 1 : 0) + (belowVWAP ? 1 : 0)
sellSignal = exitCount >= 2 and strategy.position_size > 0
strongSell = emaSellCross and close < emaTrend and strategy.position_size > 0

// ===========================
//  8. POSITION SIZING
// ===========================

capitalRisk  = strategy.equity * (riskPct / 100)
slDistance   = close * (slPct / 100)
positionSize = slDistance > 0 ? capitalRisk / slDistance : 0
finalQty     = math.min(positionSize, strategy.equity / close)

// ===========================
//  9. EXECUTION — ALL INLINED, NO FUNCTIONS MODIFYING GLOBALS
// ===========================

// --- ENTRY ---
if finalBuy
    lastEntryBar  := bar_index
    lastSignalBar := bar_index
    strategy.entry("Buy", strategy.long, qty=finalQty)

// --- LOCK LEVELS on first bar of new position (guard: na(longSL) only) ---
if strategy.position_size > 0 and na(longSL)
    float ap       = strategy.position_avg_price
    longSL            := ap * (1 - slPct        / 100)
    longTP1           := ap * (1 + tp1Pct        / 100)
    longTP2           := ap * (1 + tp2Pct        / 100)
    trailTicksLocked  := math.max(math.round(ap * (trailPct    / 100) / syminfo.mintick), 1)
    trailOffsetLocked := math.max(math.round(ap * (trailOffset / 100) / syminfo.mintick), 1)

    // Draw per-trade TP/SL lines
    if showLines
        // Delete previous lines if any
        if not na(slLine)
            line.delete(slLine)
        if not na(tp1Line)
            line.delete(tp1Line)
        if not na(tp2Line)
            line.delete(tp2Line)
        if not na(entLine)
            line.delete(entLine)

        entLine := line.new(bar_index, ap,      bar_index + 60, ap,      color=color.new(color.yellow, 0), width=lineWidth, style=line.style_dashed)
        slLine  := line.new(bar_index, longSL,  bar_index + 60, longSL,  color=color.new(color.red,    0), width=lineWidth, style=line.style_solid)
        tp1Line := line.new(bar_index, longTP1, bar_index + 60, longTP1, color=color.new(color.lime,   0), width=lineWidth, style=line.style_dotted)
        tp2Line := line.new(bar_index, longTP2, bar_index + 60, longTP2, color=color.new(color.teal,   0), width=lineWidth, style=line.style_solid)

        label.new(bar_index + 2, longSL,  "SL "  + str.tostring(longSL,  "#.##"), color=color.new(color.red,  80), textcolor=color.red,  style=label.style_label_right, size=size.tiny)
        label.new(bar_index + 2, longTP1, "TP1 " + str.tostring(longTP1, "#.##"), color=color.new(color.lime, 80), textcolor=color.lime, style=label.style_label_right, size=size.tiny)
        label.new(bar_index + 2, longTP2, "TP2 " + str.tostring(longTP2, "#.##"), color=color.new(color.teal, 80), textcolor=color.teal, style=label.style_label_right, size=size.tiny)

// --- DETECT TP1 HIT (position partially closed while in trade) ---
if strategy.position_size > 0 and strategy.position_size < strategy.position_size[1] and not na(longTP1)
    tp1Hit := true

// --- SUBMIT EXIT ORDERS every bar while in position ---
if strategy.position_size > 0 and not na(longSL)
    if not tp1Hit
        strategy.exit("TP1", "Buy", qty_percent=tp1ClosePct, stop=longSL, limit=longTP1)

    if useTrail
        strategy.exit("TP2", "Buy",
             stop         = longSL,
             limit        = longTP2,
             trail_points = trailTicksLocked,
             trail_offset = trailOffsetLocked)
    else
        strategy.exit("TP2", "Buy", stop=longSL, limit=longTP2)

// --- MANUAL SELL EXIT — inline reset (no function) ---
if sellSignal or strongSell
    strategy.close("Buy", comment=strongSell ? "STRONG SELL" : "SELL EXIT")
    lastExitBar := bar_index
    // Delete lines
    if not na(slLine)
        line.delete(slLine)
        slLine := na
    if not na(tp1Line)
        line.delete(tp1Line)
        tp1Line := na
    if not na(tp2Line)
        line.delete(tp2Line)
        tp2Line := na
    if not na(entLine)
        line.delete(entLine)
        entLine := na
    // Reset levels
    longSL            := na
    longTP1           := na
    longTP2           := na
    trailTicksLocked  := na
    trailOffsetLocked := na
    tp1Hit            := false

// --- POSITION CLOSED VIA SL/TP — inline reset ---
if strategy.position_size == 0 and not na(longSL)
    lastExitBar := bar_index
    // Delete lines
    if not na(slLine)
        line.delete(slLine)
        slLine := na
    if not na(tp1Line)
        line.delete(tp1Line)
        tp1Line := na
    if not na(tp2Line)
        line.delete(tp2Line)
        tp2Line := na
    if not na(entLine)
        line.delete(entLine)
        entLine := na
    // Reset levels
    longSL            := na
    longTP1           := na
    longTP2           := na
    trailTicksLocked  := na
    trailOffsetLocked := na
    tp1Hit            := false

// --- CONSECUTIVE LOSS TRACKER ---
if strategy.closedtrades > prevClosedTrades
    prevClosedTrades := strategy.closedtrades
    float lastPnl = strategy.closedtrades.profit(strategy.closedtrades - 1)
    if lastPnl < 0
        consLosses       := consLosses + 1
        consLossPauseBar := bar_index
    else if lastPnl > 0
        consLosses := 0

// ===========================
//  10. VISUALS
// ===========================

p1 = plot(emaFast,  "Fast EMA",  color.new(color.lime,   0), 1)
p2 = plot(emaSlow,  "Slow EMA",  color.new(color.orange, 0), 1)
plot(emaTrend, "Trend EMA", color.new(color.white, 30), 2)
fill(p1, p2, color=emaFast > emaSlow ? color.new(color.green, 85) : color.new(color.red, 85))

plot(useVWAP ? vwapVal : na, "VWAP", color.new(color.fuchsia, 0), 2, plot.style_cross)
plot(useSR and not na(supportLevel)    ? supportLevel    : na, "Support",    color.new(color.aqua, 30), 1, plot.style_stepline_diamond)
plot(useSR and not na(resistanceLevel) ? resistanceLevel : na, "Resistance", color.new(color.red,  30), 1, plot.style_stepline_diamond)

// Entry signals
plotshape(buySignal,  "BUY",     shape.triangleup,   location.belowbar, color.new(color.lime, 0), size=size.small, text="BUY")
plotshape(patternBuy, "PAT BUY", shape.diamond,       location.belowbar, color.new(color.aqua, 0), size=size.small, text="PAT\nBUY")
plotshape(sellSignal or strongSell, "SELL", shape.triangledown, location.abovebar, color.new(color.red, 0), size=size.small, text="SELL")

// Blocked signal markers (shows WHY an entry was suppressed)
suppressedEntry = (emaCross or bullPattern) and strategy.position_size == 0 and not finalBuy
plotshape(suppressedEntry and not emaTrendSlope, "Blocked:Slope",  shape.xcross, location.belowbar, color.new(color.gray,   40), size=size.tiny, text="↗?")
plotshape(suppressedEntry and nearResistance,    "Blocked:Resist", shape.xcross, location.belowbar, color.new(color.orange, 40), size=size.tiny, text="R↑")
plotshape(suppressedEntry and rsiBearDiv,        "Blocked:Div",    shape.xcross, location.belowbar, color.new(color.purple, 40), size=size.tiny, text="DIV")

// Background tints
bgcolor(finalBuy ? color.new(color.lime, 90) : na)
bgcolor(sellSignal or strongSell ? color.new(color.red, 90) : na)
bgcolor(consLossBlocked ? color.new(color.orange, 95) : na)

// Candle pattern markers (non-entry)
plotshape(bullEngulf and not finalBuy, "Engulfing", shape.arrowup, location.belowbar, color.new(color.yellow, 50), size=size.tiny)
plotshape(bullPinBar  and not finalBuy, "Pin Bar",  shape.circle,  location.belowbar, color.new(color.aqua,   50), size=size.tiny)

// ===========================
//  11. DASHBOARD
// ===========================

var table dash = table.new(position.top_right, 3, 18, color.new(color.black, 75), color.gray, 1, color.gray, 1)

checkMark(bool c) => c ? "✓" : "✗"
checkClr(bool c)  => c ? color.lime : color.new(color.red, 30)

if barstate.islast
    inPos  = strategy.position_size > 0
    ap     = strategy.position_avg_price
    pnlPct = inPos ? (close - ap) / ap * 100 : 0.0

    table.cell(dash, 0, 0, "SPOT SCALPER v4",   text_color=color.yellow, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 0, "",                  text_size=size.small)
    table.cell(dash, 2, 0, inPos ? "IN TRADE" : (consLossBlocked ? "PAUSED" : "WATCHING"),
         text_color=inPos ? color.lime : (consLossBlocked ? color.orange : color.gray), text_size=size.small)

    table.cell(dash, 0, 1, "P&L",              text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 1, str.tostring(pnlPct, "#.##") + "%",
         text_color=pnlPct >= 0 ? color.lime : color.red, text_size=size.small)
    table.cell(dash, 2, 1, "SL " + str.tostring(slPct) + "% / TP " + str.tostring(tp1Pct) + "/" + str.tostring(tp2Pct) + "%",
         text_color=color.gray, text_size=size.tiny)

    table.cell(dash, 0, 2, "Con. Losses",       text_color=color.white, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 2, str.tostring(consLosses) + "/" + str.tostring(consLossMax),
         text_color=consLosses >= consLossMax ? color.orange : color.lime, text_size=size.small)
    table.cell(dash, 2, 2, consLossBlocked ? "PAUSED" : "OK",
         text_color=consLossBlocked ? color.orange : color.lime, text_size=size.tiny)

    table.cell(dash, 0, 3, "── CONFLUENCES ──", text_color=color.gray, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 3, "", text_size=size.tiny)
    table.cell(dash, 2, 3, "", text_size=size.tiny)

    table.cell(dash, 0, 4,  "Trend (>50EMA)",   text_color=color.white, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 4,  checkMark(c_trend == 1), text_color=checkClr(c_trend == 1), text_size=size.small)
    table.cell(dash, 2, 4,  emaTrendSlope ? "RISING" : "FLAT/DOWN", text_color=checkClr(emaTrendSlope), text_size=size.tiny)

    table.cell(dash, 0, 5,  "VWAP Bias",        text_color=color.white, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 5,  checkMark(c_vwap == 1), text_color=checkClr(c_vwap == 1), text_size=size.small)
    table.cell(dash, 2, 5,  close > vwapVal ? "ABOVE" : "BELOW", text_color=checkClr(close > vwapVal), text_size=size.tiny)

    table.cell(dash, 0, 6,  "Volume Spike",     text_color=color.white, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 6,  checkMark(c_volume == 1), text_color=checkClr(c_volume == 1), text_size=size.small)
    table.cell(dash, 2, 6,  c_volume == 1 ? "SPIKE" : "NORMAL", text_color=checkClr(c_volume == 1), text_size=size.tiny)

    table.cell(dash, 0, 7,  "RSI Momentum",     text_color=color.white, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 7,  str.tostring(rsi, "#.#"), text_color=checkClr(c_rsi == 1), text_size=size.small)
    table.cell(dash, 2, 7,  rsiBearDiv ? "DIVERGENCE!" : (rsi >= rsiOB ? "OB" : rsi <= rsiOS ? "OS" : "OK"),
         text_color=rsiBearDiv ? color.orange : checkClr(c_rsi == 1), text_size=size.tiny)

    table.cell(dash, 0, 8,  "MACD Momentum",    text_color=color.white, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 8,  checkMark(c_macd == 1), text_color=checkClr(c_macd == 1), text_size=size.small)
    table.cell(dash, 2, 8,  c_macd == 1 ? "BULL↑" : "FLAT", text_color=checkClr(c_macd == 1), text_size=size.tiny)

    table.cell(dash, 0, 9,  "Candle Pattern",   text_color=color.white, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 9,  checkMark(c_candle == 1), text_color=checkClr(c_candle == 1), text_size=size.small)
    pName = bullEngulf ? "ENGULF" : bullPinBar ? "PIN BAR" : strongBull ? "STRONG" : bullCandle ? "BULL" : "BEAR"
    table.cell(dash, 2, 9,  pName, text_color=checkClr(c_candle == 1), text_size=size.tiny)

    table.cell(dash, 0, 10, "Near Support",     text_color=color.white, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 10, checkMark(c_support == 1), text_color=checkClr(c_support == 1), text_size=size.small)
    table.cell(dash, 2, 10, nearResistance ? "AT RESIST!" : (c_support == 1 ? "YES" : "NO"),
         text_color=nearResistance ? color.orange : checkClr(c_support == 1), text_size=size.tiny)

    table.cell(dash, 0, 11, "DI+ > DI-",        text_color=color.white, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 11, checkMark(c_di == 1), text_color=checkClr(c_di == 1), text_size=size.small)
    table.cell(dash, 2, 11, c_di == 1 ? "BUYERS" : "SELLERS", text_color=checkClr(c_di == 1), text_size=size.tiny)

    table.cell(dash, 0, 12, "ADX Trending",     text_color=color.white, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 12, str.tostring(adx, "#.#"), text_color=checkClr(c_adx == 1), text_size=size.small)
    table.cell(dash, 2, 12, c_adx == 1 ? "TREND" : "CHOP", text_color=checkClr(c_adx == 1), text_size=size.tiny)

    table.cell(dash, 0, 13, "Break Swing High", text_color=color.white, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 13, checkMark(c_breakout == 1), text_color=checkClr(c_breakout == 1), text_size=size.small)
    table.cell(dash, 2, 13, c_breakout == 1 ? "YES" : "NO", text_color=checkClr(c_breakout == 1), text_size=size.tiny)

    table.cell(dash, 0, 14, "── FILTERS ──",    text_color=color.gray, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 14, "", text_size=size.tiny)
    table.cell(dash, 2, 14, "", text_size=size.tiny)

    table.cell(dash, 0, 15, "EMA Slope",        text_color=color.white, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 15, checkMark(emaTrendSlope), text_color=checkClr(emaTrendSlope), text_size=size.small)
    table.cell(dash, 2, 15, emaTrendSlope ? "RISING" : "BLOCKED", text_color=checkClr(emaTrendSlope), text_size=size.tiny)

    table.cell(dash, 0, 16, "RSI Divergence",   text_color=color.white, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 16, rsiBearDiv ? "✗" : "✓", text_color=rsiBearDiv ? color.orange : color.lime, text_size=size.small)
    table.cell(dash, 2, 16, rsiBearDiv ? "DIVERGING!" : "CLEAN", text_color=rsiBearDiv ? color.orange : color.lime, text_size=size.tiny)

    table.cell(dash, 0, 17, "SCORE",            text_color=color.yellow, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 17, str.tostring(totalScore) + "/10",
         text_color=totalScore >= minBuyScore ? color.lime : color.red, text_size=size.normal)
    table.cell(dash, 2, 17, totalScore >= minBuyScore ? "READY" : "WAIT",
         text_color=totalScore >= minBuyScore ? color.lime : color.orange, text_size=size.small)

