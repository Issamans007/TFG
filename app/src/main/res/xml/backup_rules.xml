<?xml version="1.0" encoding="utf-8"?>
<!-- Auto-backup rules: exclude sensitive/ephemeral data from cloud backup -->
<full-backup-content>
    <!-- Exclude API keys and secrets stored in shared preferences -->
    <exclude domain="sharedpref" path="tfg_secure_prefs.xml" />
    <!-- Exclude the Room database files (contain order history / candles — too large & sensitive) -->
    <exclude domain="database" path="tfg_database" />
    <exclude domain="database" path="tfg_database-shm" />
    <exclude domain="database" path="tfg_database-wal" />
    <!-- Exclude widget prefs (stale on restore) -->
    <exclude domain="sharedpref" path="tfg_widget.xml" />
    <!-- Exclude trade executor state (peak prices, trailing state) -->
    <exclude domain="sharedpref" path="trade_executor.xml" />
    <!-- Exclude HTTP/image cache -->
    <exclude domain="cache" path="." />
</full-backup-content>