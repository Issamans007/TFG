<?xml version="1.0" encoding="utf-8"?>
<!-- Data extraction rules for Android 12+: controls cloud backup and device transfer -->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude Room database files (order history / candles — sensitive and too large) -->
        <exclude domain="database" path="tfg_database" />
        <exclude domain="database" path="tfg_database-shm" />
        <exclude domain="database" path="tfg_database-wal" />
        <!-- Exclude API key / secret shared prefs -->
        <exclude domain="sharedpref" path="tfg_secure_prefs.xml" />
        <!-- Exclude widget and executor transient state -->
        <exclude domain="sharedpref" path="tfg_widget.xml" />
        <exclude domain="sharedpref" path="trade_executor.xml" />
        <!-- Exclude HTTP and image cache -->
        <exclude domain="cache" path="." />
    </cloud-backup>
    <device-transfer>
        <!-- Same exclusions apply for device-to-device transfers -->
        <exclude domain="database" path="tfg_database" />
        <exclude domain="database" path="tfg_database-shm" />
        <exclude domain="database" path="tfg_database-wal" />
        <exclude domain="sharedpref" path="tfg_secure_prefs.xml" />
        <exclude domain="sharedpref" path="tfg_widget.xml" />
        <exclude domain="sharedpref" path="trade_executor.xml" />
        <exclude domain="cache" path="." />
    </device-transfer>
</data-extraction-rules>